<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <!-- 타이틀 -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="LLM 음성 테스트"
        android:textSize="22sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 모델 선택 -->
    <Spinner
        android:id="@+id/spinnerModel"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:entries="@array/model_names"
        android:padding="10dp"
        android:background="@android:drawable/spinner_background"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="14dp"/>

    <!-- 상태 텍스트 -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#FF5722"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/spinnerModel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <!-- 인식된 텍스트 -->
    <TextView
        android:id="@+id/tvRecognizedText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="마이크 버튼을 눌러 음성 입력을 시작하세요"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:gravity="center"
        android:padding="10dp"
        android:background="@android:color/white"
        app:layout_constraintTop_toBottomOf="@id/tvStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 결과 카드 (분석 결과 출력) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardResult"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvRecognizedText"
        app:layout_constraintBottom_toTopOf="@id/btnStartNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvResultProvider"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#3F51B5"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@android:color/darker_gray"
                android:layout_marginVertical="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvResultDeparture"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="출발지: -"
                    android:textSize="15sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvResultDestination"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="도착지: -"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvResultLatency"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="전체: - | LLM: -"
                android:textSize="13sp"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/tvResultCost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="크레딧: - | 토큰: -"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 길찾기 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartNavigation"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:text="🗺️  길찾기 시작"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:backgroundTint="#4CAF50"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toTopOf="@id/btnOpenCompare"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"/>

    <!-- LLM 비교 분석 버튼 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnOpenCompare"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:text="🔬  4개 LLM 동시 비교"
        android:textSize="14sp"
        app:backgroundTint="#3F51B5"
        app:cornerRadius="10dp"
        app:layout_constraintBottom_toTopOf="@id/btnRecord"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="14dp"/>

    <!-- 녹음 버튼 (1개) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnRecord"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:text="🎙️&#10;녹음 시작"
        android:textSize="15sp"
        app:cornerRadius="70dp"
        app:layout_constraintBottom_toTopOf="@id/switchDarkMode"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="14dp"/>

    <!-- 다크모드 스위치 -->
    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchDarkMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="다크 모드"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp"/>

    <!-- 로딩 인디케이터 (오버레이) -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:visibility="gone"
        android:elevation="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
