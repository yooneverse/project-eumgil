{
  "priority": [
    {
      "if": "walk_access == NO",
      "multiply_by": "0"
    },
    {
      "if": "walk_access == UNKNOWN",
      "multiply_by": "0.80"
    },
    {
      "if": "stairs_state == YES",
      "multiply_by": "0.45"
    },
    {
      "if": "stairs_state == UNKNOWN",
      "multiply_by": "0.85"
    },
    {
      "if": "avg_slope_percent >= 3.0 && avg_slope_percent < 5.56",
      "multiply_by": "0.75"
    },
    {
      "if": "avg_slope_percent >= 5.56 && avg_slope_percent < 8.33",
      "multiply_by": "0.50"
    },
    {
      "if": "avg_slope_percent >= 8.33",
      "multiply_by": "0.20"
    },
    {
      "if": "width_state == ADEQUATE_120",
      "multiply_by": "0.95"
    },
    {
      "if": "width_state == NARROW",
      "multiply_by": "0.75"
    },
    {
      "if": "width_state == UNKNOWN",
      "multiply_by": "0.90"
    },
    {
      "if": "surface_state == UNPAVED",
      "multiply_by": "0.70"
    },
    {
      "if": "surface_state == UNKNOWN",
      "multiply_by": "0.85"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == YES",
      "multiply_by": "1.10"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == NO",
      "multiply_by": "0.60"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == UNKNOWN",
      "multiply_by": "0.80"
    },
    {
      "if": "braille_block_state == YES",
      "multiply_by": "1.08"
    },
    {
      "if": "braille_block_state == NO",
      "multiply_by": "0.90"
    },
    {
      "if": "braille_block_state == UNKNOWN",
      "multiply_by": "0.95"
    },
    {
      "if": "audio_signal_state == YES",
      "multiply_by": "1.10"
    },
    {
      "if": "audio_signal_state == NO",
      "multiply_by": "0.85"
    },
    {
      "if": "audio_signal_state == UNKNOWN",
      "multiply_by": "0.95"
    }
  ],
  "speed": [
    {
      "if": "true",
      "limit_to": "2.88"
    }
  ],
