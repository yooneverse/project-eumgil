{
  "priority": [
    {
      "if": "walk_access == NO",
      "multiply_by": "0"
    },
    {
      "if": "walk_access == UNKNOWN",
      "multiply_by": "0.65"
    },
    {
      "if": "avg_slope_percent >= 15.0",
      "multiply_by": "0"
    },
    {
      "if": "stairs_state == YES",
      "multiply_by": "0.00"
    },
    {
      "if": "stairs_state == UNKNOWN",
      "multiply_by": "0.60"
    },
    {
      "if": "avg_slope_percent >= 3.0 && avg_slope_percent < 5.56",
      "multiply_by": "0.45"
    },
    {
      "if": "avg_slope_percent >= 5.56 && avg_slope_percent < 8.33",
      "multiply_by": "0.10"
    },
    {
      "if": "avg_slope_percent >= 8.33 && avg_slope_percent < 15.0",
      "multiply_by": "0.05"
    },
    {
      "if": "width_state == ADEQUATE_120",
      "multiply_by": "0"
    },
    {
      "if": "width_state == NARROW",
      "multiply_by": "0"
    },
    {
      "if": "width_state == UNKNOWN",
      "multiply_by": "0.75"
    },
    {
      "if": "surface_state == UNPAVED",
      "multiply_by": "0.25"
    },
    {
      "if": "surface_state == UNKNOWN",
      "multiply_by": "0.70"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == YES",
      "multiply_by": "1.05"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == NO",
      "multiply_by": "0.75"
    },
    {
      "if": "segment_type == CROSS_WALK && signal_state == UNKNOWN",
      "multiply_by": "0.85"
    }
  ],
  "speed": [
    {
      "if": "true",
      "limit_to": "1.80"
    }
  ],
  "distance_influence": 50
}
